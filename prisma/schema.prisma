// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model SeoJob {
  id          String   @id @default(cuid())
  shop        String
  status      String   @default("pending") // pending, processing, completed, failed
  jobType     String   // "meta_generation", "schema_generation", "blog_generation"
  totalItems  Int      @default(0)
  processed   Int      @default(0)
  errors      String?  // JSON string of errors
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductSeoData {
  id              String   @id @default(cuid())
  shop            String
  productId       String   // Shopify GID e.g. "gid://shopify/Product/123"
  originalTitle   String?
  originalDesc    String?
  generatedMeta   String?  // JSON: { metaTitle, metaDescription }
  generatedSchema String?  // JSON-LD string
  applied         Boolean  @default(false)
  schemaApplied   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, productId])
}

model AppSettings {
  id                String   @id @default(cuid())
  shop              String   @unique
  aiApiKey          String?  // encrypted Anthropic API key
  aiModel           String   @default("claude-sonnet-4-6")
  metaTitleTemplate String?  // token-based template e.g. "{title} - {type} | {vendor}"
  metaDescTemplate  String?  // token-based description template
  templateRules     String?  // JSON: [{productType, titleTemplate, descTemplate}]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GeneratedContent {
  id          String   @id @default(cuid())
  shop        String
  contentType String   // "buying_guide", "product_spotlight", "comparison"
  title       String
  metaDesc    String?
  body        String   // Markdown
  productIds  String   // JSON array of product GIDs
  published   Boolean  @default(false)
  articleId   String?  // Shopify article GID if published
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GscAccount {
  id           String   @id @default(cuid())
  shop         String   @unique
  accessToken  String
  refreshToken String?
  scope        String?
  tokenType    String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GscOauthState {
  id        String   @id @default(cuid())
  shop      String
  state     String   @unique
  createdAt DateTime @default(now())
  usedAt    DateTime?
}

model AutomationRule {
  id        String   @id @default(cuid())
  shop      String
  ruleType  String   // "product_create_meta", "product_create_schema", "weekly_meta", "weekly_schema"
  enabled   Boolean  @default(false)
  autoApply Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, ruleType])
}

model SeoChangeQueue {
  id           String   @id @default(cuid())
  shop         String
  productId    String
  productTitle String
  changeType   String   // "meta" | "schema"
  payload      String   // JSON string
  status       String   @default("pending") // pending, applied, skipped, failed
  error        String?
  appliedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
